# DS4 V100 appliance deployment config.
# Copy to an operator-owned path such as /etc/ds4-v100/appliance.env.

DS4_V100_BIN=./tools/ds4-v100-replay
DS4_V100_MODEL=/models/DSv4-Flash-256e-fixed.gguf
DS4_V100_MTP_MODEL=/models/DeepSeek-V4-Flash-MTP-Q4K-Q8_0-F32.gguf
DS4_V100_PACK_INDEX=docs/sprints/drafts/SPRINT-003-PACK-INDEX.tsv

DS4_V100_CTX=1048576
DS4_V100_SLOTS=4
DS4_V100_ACTIVE_MICROBATCH=4
DS4_V100_QUEUE_POLICY=sequential
DS4_V100_TOKENS=16
DS4_V100_ASYNC_PIPELINE_MODE=auto
DS4_V100_ASYNC_HANDOFF=0
DS4_V100_ASYNC_EVENT_HANDOFF=0
DS4_V100_DISABLE_OUTPUT_HEAD_FASTPATH=0
DS4_V100_ENABLE_OUTPUT_HEAD_BATCH=0
DS4_V100_TURBOMIND_ROUTED_FFN=0
DS4_V100_TURBOMIND_STRICT=0
DS4_V100_TURBOMIND_LIB=./build/turbomind-v100/libggml-turbomind.so

DS4_V100_HOST=127.0.0.1
DS4_V100_PORT=18080

DS4_V100_CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
DS4_V100_REQUIRE_GPUS=8
DS4_V100_RESERVE_MIB=4096

# 0 means run until the supervisor stops the process.
DS4_V100_MAX_REQUESTS=0
DS4_V100_LOG_DIR=logs/v100-appliance

# Production serving defaults to the measured base multi-slot path. With
# DS4_V100_ASYNC_PIPELINE_MODE=auto, the launcher selects the faster per-step
# async pipeline when DS4_V100_ACTIVE_MICROBATCH > 1 and leaves one-slot
# latency configs serial. The mailbox mode and async handoff are opt-in until
# V100 evidence decides whether they should replace the measured per-step path.
# Event-ordered async handoff is also opt-in pending V100 A/B evidence.
# Greedy output selection defaults to the measured parallel device top-1 path;
# set DS4_V100_DISABLE_OUTPUT_HEAD_FASTPATH=1 to roll back to full-logit host
# top-k selection for diagnostics.
# Batched output-head selection is correct but slower on the measured 1M/4-slot
# fixture; keep DS4_V100_ENABLE_OUTPUT_HEAD_BATCH=0 unless re-benchmarking that
# specific path.
# DS4_V100_TURBOMIND_ROUTED_FFN is an opt-in transient routed-expert bridge.
# It proves the copied TurboMind MXFP4 kernel at the DS4 runtime boundary but
# repacks expert weights per call, so it is not a production throughput default.
# DS4_V100_TURBOMIND_STRICT=1 fails instead of falling back to the source-MXFP4
# arena path, which is useful for focused validation.
# Set DS4_V100_MTP_SERVING=verify to expose the conservative MTP draft/verify
# diagnostics path, or commit to exercise the exact-verified one-slot MTP commit
# path.
DS4_V100_SERVE_MODE=base
DS4_V100_MTP_SERVING=off
DS4_V100_MTP_TOP_K=5
DS4_V100_MTP_GPU=7

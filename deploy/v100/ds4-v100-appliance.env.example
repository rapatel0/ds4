# DS4 V100 appliance deployment config.
# Copy to an operator-owned path such as /etc/ds4-v100/appliance.env.

DS4_V100_BIN=./tools/ds4-v100-replay
DS4_V100_MODEL=/models/DSv4-Flash-256e-fixed.gguf
DS4_V100_MTP_MODEL=/models/DeepSeek-V4-Flash-MTP-Q4K-Q8_0-F32.gguf

# Preferred production path after Sprint 090. When non-empty, the launcher
# validates this single appliance directory and passes --appliance-dir to the
# runtime instead of using DS4_V100_PACK_INDEX as a source-GGUF scheduler map.
DS4_V100_APPLIANCE_DIR=/workspace/packs/ds4-appliance-full-tm-gated-s181

DS4_V100_PACK_INDEX=docs/sprints/drafts/SPRINT-003-PACK-INDEX.tsv

DS4_V100_CTX=262144
DS4_V100_SLOTS=32
DS4_V100_ACTIVE_MICROBATCH=32
DS4_V100_MICROBATCH_WAIT_US=auto
DS4_V100_QUEUE_POLICY=sequential
DS4_V100_TOKENS=16
DS4_V100_ASYNC_PIPELINE_MODE=auto
DS4_V100_ASYNC_HANDOFF=0
DS4_V100_ASYNC_EVENT_HANDOFF=auto
# Empty keeps the measured per-slot stage pipeline. Setting this forces per-step
# async to process multiple slots per stage chunk for diagnostics.
DS4_V100_ASYNC_SLOT_CHUNK=
DS4_V100_STARTUP_WARMUP=auto
# Resolve CUDA runtime libraries for the appliance binary. `auto` uses the
# node-local CUDA install under /localpool when present.
DS4_V100_CUDA_LIB_DIR=auto
DS4_V100_CUDA_PROFILER_WINDOW=0
DS4_V100_CUDA_TENSOR_POOL=auto
DS4_V100_CUDA_TENSOR_POOL_MAX_MIB=2048
DS4_V100_CUDA_F8_ROWPAIR=1
DS4_V100_CUDA_F8_ROW4=0
DS4_V100_CUDA_F8_WARP_SCALE=0
DS4_V100_CUDA_F8_GROUPED_DS4_FAST=1
DS4_V100_CUDA_F8_HMMA_SHARED_DOWN=0
DS4_V100_CUDA_F8_HMMA_PAIR_SWIGLU=1
DS4_V100_CUDA_F8_HMMA_ATTN_BATCH=1
DS4_V100_CUDA_F8_HMMA_GROUPED_ATTN_O_BATCH=0
DS4_V100_CUDA_F8_HMMA_GROUPED_ATTN_O_SINGLE=0
DS4_V100_CUDA_F8_HMMA_SINGLE=0
DS4_V100_CUDA_F8_PAIR_SWIGLU_SINGLE=0
DS4_V100_CUDA_F8_PAIR_SWIGLU_SINGLE_ROWS2=0
DS4_V100_F8_SHARED_DOWN_ADD=0
DS4_V100_ENABLE_BATCH_ATTN_PROJ=1
DS4_V100_BATCH_ATTN_OUTPUT_A=0
DS4_V100_BATCH_ATTN_OUTPUT_B=0
DS4_V100_DISABLE_OUTPUT_HEAD_FASTPATH=0
DS4_V100_ENABLE_OUTPUT_HEAD_BATCH=0
DS4_V100_BATCH_SHARED_F8=1
DS4_V100_FFN_DIRECT_DELTA=0
DS4_V100_DISABLE_GROUPED_ATTN_OUTPUT_A=0
DS4_V100_SINGLE_SLOT_ATTN_OUTPUT_A_HMMA=0
DS4_V100_TURBOMIND_ROUTED_FFN=0
DS4_V100_TURBOMIND_STRICT=0
DS4_V100_DISABLE_TURBOMIND_TOTAL_TOKENS=1
DS4_V100_TURBOMIND_ROUTE_VALIDATE_SYNC=0
DS4_V100_TURBOMIND_SMALL_ROUTE_BUILD=0
DS4_V100_TURBOMIND_ROUTE_ROW_REDUCE=0
DS4_V100_TURBOMIND_ROUTE_ROW_REDUCE_H2=0
DS4_V100_TURBOMIND_INDEXED_A=0
DS4_V100_TURBOMIND_FUSED_GATE_UP=1
DS4_V100_TURBOMIND_GATED_SILU=1
DS4_V100_TURBOMIND_COMPACT_SCHEDULE=1
DS4_V100_TURBOMIND_COMPACT_NO_HOST_SYNC=0
DS4_V100_SINGLE_SLOT_ATTN_SCRATCH=1
DS4_V100_TURBOMIND_ROUTED_EXECUTOR=fused6_reduce
DS4_V100_TURBOMIND_ROUTED_EXECUTOR_VERBOSE=0
DS4_V100_TURBOMIND_GATE_UP_PROBE=auto
DS4_V100_TURBOMIND_DOWN_PROBE=off
DS4_V100_TURBOMIND_DOWN_REDUCE_EPILOGUE=0
DS4_V100_TURBOMIND_DISPATCH_POLICY=default
DS4_V100_TURBOMIND_ALLOW_UNSAFE_MEASURE=0
DS4_V100_TURBOMIND_GROUP_PIPELINE=0
DS4_V100_TURBOMIND_GROUP_PIPELINE_STREAMS=8
DS4_V100_TURBOMIND_GROUP_PIPELINE_AUTO_GROUPS=0
DS4_V100_TURBOMIND_GRAPH=1
DS4_V100_TURBOMIND_GRAPH_VERBOSE=0
DS4_V100_TURBOMIND_PROFILE=0
DS4_V100_TURBOMIND_LIB=./build/turbomind-v100/libggml-turbomind.so
DS4_V100_TP_EP_PARALLEL_HALVES=0
DS4_V100_TP_EP_PARALLEL_EXPERT_LOAD=1
DS4_V100_TP_EP_COPY_EVENT_COMPOSE=1
DS4_V100_TP_EP_RETURN_FP16=0
DS4_V100_TP_EP_COMPACT_ROUTE_COMPOSE=1
DS4_V100_TP_EP_COMPACT_MOE_DECODE=1
DS4_V100_TP_EP_NCCL_REDUCE_SCATTER_COMPOSE=auto
DS4_V100_TP_EP_HC_FINAL_EXPAND=1
DS4_V100_TP_EP_HC_CURRENT_INPUT=1
DS4_V100_TP_EP_HC_CURRENT_INPUT_NCCL_ALLGATHER=1
DS4_V100_TP_EP_HC_CURRENT_ALLREDUCE=1
DS4_V100_TP_EP_HC_CURRENT_INPUT_STREAM_SYNC=1
# Permanent TP/EP peer-copy diagnostics. Keep off in production unless a
# topology audit is running; reject-sys intentionally fails any direct peer
# copy classified as a SYS edge.
DS4_V100_TP_EP_PEER_ACCOUNTING=0
DS4_V100_TP_EP_PEER_REJECT_SYS=0
DS4_V100_TP_EP_HC_PERSIST_STATE=1
DS4_V100_TP_EP_KV_ALL_SLOTS=0
DS4_V100_TP_EP_MODEL_ROUTER_ROUTES=1
DS4_V100_TP_EP_ROUTED_FFN_NORM_INPUT=1
# Rank-major router/FFN remains available, but the promoted graph-serving
# default follows the exact 32-slot/256K parity-passing route-plan shape.
DS4_V100_TP_EP_ROUTED_FFN_RANK_MAJOR_INPUT=0
DS4_V100_TP_EP_MODEL_ROUTER_RANK_MAJOR_LOGITS=0
# Promoted Pattern-A router path: rank-local router partial logits plus NCCL
# all-reduce across ranks. Numeric logit drift is advisory; selected-token and
# generated-sequence agreement gate promotion.
DS4_V100_TP_EP_MODEL_ROUTER_ALLREDUCE_LOGITS=1
# Promoted TP/EP graph-serving path: compute and upload a GPU route plan so the
# captured per-layer graph sees stable route metadata at serving time.
DS4_V100_TP_EP_GPU_ROUTE_PLAN=1
# Promoted with router rank-major serving: keep per-rank route buffers at
# slots*top_k so the current post-attention route/pack shape remains stable.
# This over-computes inactive routes, but it is the validated 28-slot semantic
# path for the promoted router+FFN rank-major bundle.
DS4_V100_TP_EP_POST_ATTENTION_FIXED_CAPACITY_ROUTE_PLAN=1
# Diagnostic upper-bound mode: synchronize device route totals back to host and
# launch only actual routed rows. This is not CUDA-graph safe; use only to decide
# whether a graph-safe active executor is worth building.
DS4_V100_TP_EP_POST_ATTENTION_DEVICE_ACTUAL_ROUTE_SYNC=0
# Diagnostic force switch: keep the old slot-major FFN norm materialization even
# when every downstream consumer can read rank-major input. This exists as a
# correctness bisect against the skip switch below.
DS4_V100_TP_EP_POST_ATTENTION_SLOT_MAJOR_FFN_NORM=0
# Diagnostic rank-major path: skip redundant slot-major FFN norm staging when
# router logits and shared/routed FFN consumers are all rank-major capable.
DS4_V100_TP_EP_POST_ATTENTION_SKIP_SLOT_MAJOR_FFN_NORM=0
# Diagnostic TP/EP graph path: preserve fixed route-capacity launch/copy shape
# while masking inactive compact route rows inside the device copy kernel.
# Keep off unless HTTP response parity accepts it for the target serving shape.
DS4_V100_TP_EP_POST_ATTENTION_MASKED_COMPACT_COPY=0
DS4_V100_TP_EP_TRUE_SHARED_FFN=1
DS4_V100_TP_EP_DIAGNOSTIC_OUTPUT_HEAD=1
DS4_V100_TP_EP_DIAGNOSTIC_OUTPUT_HEAD_LAZY=1
DS4_V100_TP_EP_DECODE_CUDAGRAPH=0
DS4_V100_TP_EP_DECODE_CUDAGRAPH_OUTPUT_SYNC=0
DS4_V100_TP_EP_DECODE_CUDAGRAPH_HC_CURRENT_SYNC=0
DS4_V100_TP_EP_DECODE_CUDAGRAPH_STAGE_SYNC=
DS4_V100_TP_EP_DECODE_CUDAGRAPH_SUFFIX_STAGE=
DS4_V100_TP_EP_DECODE_CUDAGRAPH_PERSISTENT=0
DS4_V100_TP_EP_DECODE_STAGE_CHECKSUM=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_RESIDENCY=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_PROJECTION=0
# Experimental TP/EP path: derive attention projection inputs from each rank's
# resident HC instead of copying the canonical device-0 normalized HC to all ranks.
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_PROJECTION_RANK_LOCAL_INPUT=0
# A6 PATH 4: consume the HC-current NCCL allgather rank-major buffer for
# attention projection input norm. Promoted after Sprint 483 parity/tolerance
# and same-shape timing evidence.
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_PROJECTION_RANK_MAJOR_INPUT=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_STATE=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_ROPE=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_SATURATION_AUDIT=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_KV_NORM_REFERENCE=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_RAW_READ=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_RAW_WINDOW=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_OUTPUT=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_OUTPUT_NCCL_ALLGATHER=0
DS4_V100_TP_EP_TRUE_DS4_POST_ATTENTION_FFN_INPUT=0
DS4_V100_TP_EP_TRUE_DS4_SEMANTIC_SKIP_STATS=auto
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_RAW=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_COMPRESSED=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_INDEXER=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_HISTORY=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_SKIP_CURRENT_LOAD=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_SKIP_RAW_STORE=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_SKIP_COMPRESSED_STORE=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_SKIP_INDEXER_STORE=0
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_QUIET=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_BATCH_ROWS=1
DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_STREAM_SYNC=1
DS4_V100_TP_EP_TP_RUNTIME_SKIP_UNUSED_COMP_STATE=1
DS4_V100_TP_EP_TP_RUNTIME_SCRATCH_MIB=1024
DS4_V100_TP_EP_DEFER_NCCL_INIT=1
# Production TP/EP fabric policy. Keep physical rank order stable and force the
# hot NCCL collectives onto the V100 no-SYS NVLink ring:
# 0 -> 3 -> 2 -> 1 -> 5 -> 7 -> 6 -> 4 -> 0.
DS4_V100_NCCL_TOPOLOGY_POLICY=no-sys
DS4_V100_NCCL_NO_SYS_RING="0 3 2 1 5 7 6 4"
DS4_V100_NCCL_ALLOW_VISIBLE_REMAP=0
# Let NCCL choose per-message algorithms/protocols by default. For latency-bound
# HC/router reductions, test Tree+LL128 explicitly via these knobs; do not force
# Ring globally in production unless a measured workload requires it.
DS4_V100_NCCL_ALGO=auto
DS4_V100_NCCL_PROTO=auto

DS4_V100_HOST=127.0.0.1
DS4_V100_PORT=18080
DS4_V100_ALLOW_NONLOCAL_HOST=0

DS4_V100_CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
DS4_V100_REQUIRE_GPUS=8
DS4_V100_RESERVE_MIB=4096
# Diagnostic-only admission override for experiments that intentionally test
# above the context-aware slot cap. Leave empty in production.
DS4_V100_EXPERIMENTAL_CTX_SLOT_CAP=

# 0 means run until the supervisor stops the process.
DS4_V100_MAX_REQUESTS=0
DS4_V100_LOG_DIR=logs/v100-appliance
# Per-process lock file consumed by ds4.c. Keep this under the run log dir so
# root-owned stale files in /tmp cannot block the appliance.
DS4_LOCK_FILE=logs/v100-appliance/ds4.lock

# Production serving defaults to the measured base multi-slot path. With
# DS4_V100_ASYNC_PIPELINE_MODE=auto, the launcher selects the faster per-step
# async pipeline when DS4_V100_ACTIVE_MICROBATCH > 1 and leaves one-slot
# latency configs serial. Event-ordered handoff also defaults to auto and is
# enabled for that measured multi-slot per-step path. The mailbox mode and
# async memcpy handoff remain opt-in until V100 evidence decides whether they
# should replace the measured per-step path.
# DS4_V100_ASYNC_SLOT_CHUNK is diagnostic-only: larger chunks expose denser
# layer/FFN batch shapes but reduce stage overlap on the V100 layer-split path.
# Startup warmup defaults to auto: multi-slot serving runs one internal
# generation before listening so concurrent first traffic cannot race lazy CUDA
# tensor-cache loading. Set DS4_V100_STARTUP_WARMUP=0 for profiling cold start.
# Request microbatch rendezvous defaults to auto: multi-slot serving waits
# 50ms for 2-15 active slots and 200ms for >=16 active slots, which is small
# compared with current V100 decode latency and prevents avoidable split
# batches in high-slot throughput serving.
# TP/EP expert residency loads in parallel across all eight GPUs per layer by
# default. This removes the old GPU-by-GPU round-robin startup load pattern.
# Set DS4_V100_TP_EP_PARALLEL_EXPERT_LOAD=0 only to bisect startup behavior.
# Sprint 219 admits 32 active slots for the warmed 256K production serving
# path. The cold DS4_V100_STARTUP_WARMUP=0 path remains capped at 16 slots for
# 256K because Sprint 218 localized a cold first-request NaN before the output
# head. The launcher keeps long-context configs memory-safe by rejecting slot
# counts above the context admission cap.
# DS4_V100_EXPERIMENTAL_CTX_SLOT_CAP can override that cap for explicit cluster
# experiments. Do not set it for production serving until V100 memory telemetry
# and correctness evidence justify a new default.
# DS4_V100_CUDA_PROFILER_WINDOW=1 is a diagnostic mode for nvprof/Nsight runs:
# generation batches call cudaProfilerStart/Stop after startup warmup.
# DS4_V100_CUDA_TENSOR_POOL=auto enables a bounded CUDA scratch tensor pool for
# multi-slot serving and disables it for one-slot latency configs. The pool
# removes per-token cudaMalloc/cudaFree churn without changing model weights or
# KV residency. Keep the cap conservative on 32 GiB V100s unless memory
# telemetry proves a larger pool is safe.
# F8 row-pair arena matmul kernels are enabled after Sprint 102. Set
# DS4_V100_CUDA_F8_ROWPAIR=0 to restore the older one-output-row-per-CTA F8
# arena matmul kernels for A/B diagnostics.
# DS4_V100_CUDA_F8_ROW4=1 enables the Sprint 109 four-output-row CTA probe for
# the hottest F8 source matmul paths. Keep it off unless V100 A/B proves a gain.
# DS4_V100_CUDA_F8_WARP_SCALE=1 enables the Sprint 112 warp-broadcast E8M0
# scale probe for F8 row-pair kernels. Correctness passed, but 8-slot/256K
# throughput regressed, so keep it off outside diagnostics.
# Greedy output selection defaults to the measured parallel device top-1 path;
# set DS4_V100_DISABLE_OUTPUT_HEAD_FASTPATH=1 to roll back to full-logit host
# top-k selection for diagnostics.
# Batched output-head selection is correct but slower on the measured 1M/4-slot
# fixture; keep DS4_V100_ENABLE_OUTPUT_HEAD_BATCH=0 unless re-benchmarking that
# specific path.
# Shared F8 FFN batching is enabled for multi-slot serving after Sprint 094
# measured it faster with grouped TurboMind routed experts. Set
# DS4_V100_BATCH_SHARED_F8=0 to isolate routed-only performance.
# DS4_V100_FFN_DIRECT_DELTA=1 makes the shared FFN write the final delta batch
# and has TurboMind routed experts accumulate into it. It is opt-in until the
# Sprint 113 V100 A/B result is accepted as the production default.
# Grouped attention output-A F8 matmul is enabled after Sprint 098. Set
# DS4_V100_DISABLE_GROUPED_ATTN_OUTPUT_A=1 to restore the older one-launch-per
# output group path for A/B diagnostics.
# DS4_V100_CUDA_F8_GROUPED_DS4_FAST=1 uses the DS4-specific grouped rows2
# attention-output-A kernel for the fixed 8 x 1024 x 4096 shape. Set to 0 to
# restore the generic grouped rows2 kernel for A/B diagnostics.
# DS4_V100_CUDA_F8_HMMA_SHARED_DOWN=1 enables the Sprint 114 Volta HMMA probe
# for the shared-FFN down projection batch shape [tokens x 2048] x
# [4096 x 2048]^T. Keep it off until V100 same-binary A/B accepts it.
# DS4_V100_CUDA_F8_HMMA_PAIR_SWIGLU=1 enables the Sprint 115 Volta HMMA path
# for the shared-FFN gate/up projections plus SwiGLU batch shape. Same-binary
# V100 A/B accepted this path as the default; set to 0 for rollback.
# DS4_V100_ENABLE_BATCH_ATTN_PROJ=1 batches attention q_a, kv_latent, and q_b
# projections across active 4/8-slot batches. DS4_V100_CUDA_F8_HMMA_ATTN_BATCH=1
# swaps those batched projection GEMVs to the Sprint 116 Volta HMMA path for
# the fixed DS4 attention shapes. Set either to 0 to roll back to per-slot
# projection execution.
# DS4_V100_BATCH_ATTN_OUTPUT_B=1 enables the guarded 16-slot attention output-B
# batch probe. Sprint 122 measured it neutral in the current event-handoff
# serving topology, so keep it off by default.
# DS4_V100_BATCH_ATTN_OUTPUT_A=1 enables the Sprint 125 grouped 16-slot
# attention output-A batch probe. Pair it with DS4_V100_BATCH_ATTN_OUTPUT_B=1
# and DS4_V100_CUDA_F8_HMMA_GROUPED_ATTN_O_BATCH=1 for the full candidate.
# DS4_V100_SINGLE_SLOT_ATTN_OUTPUT_A_HMMA=1 and
# DS4_V100_CUDA_F8_HMMA_GROUPED_ATTN_O_SINGLE=1 enable the Sprint 192
# single-slot grouped attention output-A HMMA probe. It is off by default until
# filled-context V100 A/B accepts it.
# DS4_V100_TP_EP_TRUE_DS4_SEMANTIC_SKIP_STATS=auto skips per-layer
# attention-output and post-attention tensor-stat readbacks in TP/EP semantic
# serving. Auto enables it only when post-attention FFN input is active.
# DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_HISTORY=1 is the current
# TP/EP serving integration gate for the production typed KV arena. It
# cascades on typed raw-SWA, compressed-attention, and ratio-4 indexer KV row
# store/load gates plus the true-DS4 raw-window dependencies. Leave it off
# for baseline diagnostics until the typed-KV HTTP serving gate is accepted.
# DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_SKIP_CURRENT_LOAD=1 keeps the
# production typed KV store but avoids immediately loading the same current row
# back from typed KV in the hot layer step. It is a performance probe; leave
# off for strict current-row roundtrip diagnostics.
# DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_SKIP_*_STORE=1 are
# diagnostic-only cost-isolation probes. They are not production-correct
# because they bypass production typed persistence for the selected row family
# while keeping f32 staging alive for measurement.
# DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_QUIET=1 suppresses per-layer
# typed KV PASS logs while preserving typed KV semantics. Use it for serving
# throughput measurements after correctness has been proven by a verbose run.
# DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_BATCH_ROWS=1 uses batched
# DS4_V100_TP_EP_TP_RUNTIME_SKIP_UNUSED_COMP_STATE=1 skips the currently
# unused TP-runtime compressed-state arena. The active TP/EP path keeps
# compression state in the RankState mirrors today; this is the promoted
# target-shape NCCL memory default after Sprint 409.
# DS4_V100_TP_EP_DECODE_CUDAGRAPH_PERSISTENT=1 enables per-layer persistent
# CUDA graph replay in the TP/EP token-major path. Sprint 417 measured a 2.27x
# decode improvement over eager direct decode at 8 slots / 256K context.
# DS4_V100_TP_EP_TP_RUNTIME_SCRATCH_MIB controls the per-GPU TP runtime scratch
# arena. The default is 1280 MiB after Sprint 455: it preserves the strict
# 1536 MiB reserve for the 32-slot / 256K / 32-token HTTP serving target while
# keeping the router+FFN rank-major throughput win.
# DS4_V100_TP_EP_DEFER_NCCL_INIT=1 initializes NCCL after model residency.
# This made current-HC NCCL fit in the Sprint 417 all-resident direct path and
# produced the current best 16-slot / 256K direct decode number.
# slot-major typed row store/load APIs. It preserves typed KV semantics while
# reducing per-slot host calls and row-kernel launches.
# DS4_V100_TP_EP_TRUE_DS4_ATTENTION_TYPED_KV_STREAM_SYNC=1 narrows typed KV
# row barriers from device-wide synchronization to the row-kernel stream.
# DS4_V100_CUDA_F8_HMMA_SINGLE=1 enables the Sprint 118 opt-in probe that
# dispatches the hot 4096 x 8192 per-slot F8 projection through HMMA.
# DS4_V100_CUDA_F8_PAIR_SWIGLU_SINGLE=1 enables the Sprint 117 per-slot shared
# gate/up/SwiGLU scalar fusion. It is correct but not a default throughput win.
# DS4_V100_F8_SHARED_DOWN_ADD=1 fuses the shared-FFN down projection epilogue
# with the routed/shared add. It is opt-in until same-binary V100 A/B accepts it.
# DS4_V100_CUDA_F8_PAIR_SWIGLU_SINGLE_ROWS2=1 uses the Sprint 120 row-pair
# probe inside that per-slot fusion path. It only has an effect when
# DS4_V100_CUDA_F8_PAIR_SWIGLU_SINGLE=1.
# DS4_V100_APPLIANCE_DIR is the production TurboMind expert path. The older
# DS4_V100_TURBOMIND_ROUTED_FFN flag is only for the transient source-layout
# bridge that repacks expert weights per call, so it is not a production
# throughput default.
# DS4_V100_TURBOMIND_STRICT=1 fails instead of falling back to the source-MXFP4
# arena path, which is useful for focused validation.
# Sprint 100 added a TurboMind ABI that passes the routed row count from DS4
# instead of synchronously reading expert_offsets[num_experts] back from device,
# but V100 A/B testing showed the older ABI is still faster because the wait
# moves to existing device synchronizations. Keep it disabled for production
# and set DS4_V100_DISABLE_TURBOMIND_TOTAL_TOKENS=0 only for focused probes.
# Route validation avoids a per-layer sync in normal serving. Set
# DS4_V100_TURBOMIND_ROUTE_VALIDATE_SYNC=1 for focused route-debug runs.

# DS4_V100_TURBOMIND_FUSED_GATE_UP=1 uses fused offline-packed gate_up
# expert tensors when the appliance was produced with --fuse-gate-up.
# Set to 0 only for appliances that also retain separate gate/up tensors.
# DS4_V100_TURBOMIND_GATED_SILU=1 uses the new TurboMind gated-SiLU epilogue
# for appliances produced with --fuse-gate-up-interleaved. This is the default
# for the Sprint 181+ production V100 appliance pack; set it to 0 only for
# existing [gate rows][up rows] fused appliances.
# DS4_V100_TURBOMIND_COMPACT_SCHEDULE=1 compacts the 256-expert routed schedule
# to at most total_routes grouped entries before TurboMind gate/up and down
# GEMMs. Sprint 128 promoted this after same-binary A/B cleared the run band.
# DS4_V100_TURBOMIND_ROUTED_EXECUTOR selects an explicit routed-FFN executor
# family. off keeps the generic path. fixed96/chain96/ffn96 is the Sprint 158
# 16-slot/256K probe: it first compacts active experts, logs the active-expert
# shape when verbose is set, and uses the fixed 96-route gate_up kernel only
# when compaction yields exactly six active expert groups. auto also permits
# the 768-route diagnostic executor when its compacted shape is valid.
# fused6 removes route-expanded activation staging for the served six-route
# shape. fused6_reduce additionally requires the six-route down-reduce epilogue
# and elides the route-expanded down_routes buffer. Sprint 199 promoted
# fused6_reduce together with graph replay for the Sprint 181+ production V100
# appliance pack after the 16-slot/256K served gate improved continuation tok/s
# by about 19.7% versus the routed-executor-off production control.
# DS4_V100_TURBOMIND_GATE_UP_PROBE=auto selects the fixed-shape DS4/V100
# m128 compact gated-SiLU probe for the 768-route high-slot shape when the
# interleaved gated-SiLU pack is active. Set off to force generic TurboMind.
# Sprint 144 also exposes m64n256/n256 as explicit tile-sweep probes; keep
# auto for production because served A/B regressed with m64n256.
# Sprint 148 exposes stage-4 software-pipeline probes such as m128_s4,
# m64_s4, and m128_s4_1536. Keep these explicit because served/profile A/B
# stayed inside the run band.
# Sprint 152 exposes stage-3 software-pipeline probes such as m128_s3,
# m64_s3, and m128_s3_1536. Keep these explicit because the 2/3/4-stage sweep
# stayed neutral.
# DS4_V100_TURBOMIND_DOWN_PROBE=auto selects the fixed-shape DS4/V100 m128
# compact down probe for the 768-route high-slot shape. Sprint 140 kept it
# opt-in because served A/B was slower than generic TurboMind. Sprint 144 also
# exposes m64n256/n256, but that remains an experiment-only probe.
# DS4_V100_TURBOMIND_DOWN_REDUCE_EPILOGUE=1 selects the Sprint 142 fixed-shape
# down-GEMM epilogue that applies route weights and accumulates directly into
# token rows for the 768-route high-slot shape; Sprint 147 extends the same
# diagnostic to 1536 routes. It is correct but remains off because served A/B
# was only run-noise positive versus control.
# DS4_V100_TURBOMIND_DISPATCH_POLICY selects TurboMind's grouped GEMM launch
# policy. default uses the normal heuristic/cache path. reuse requests a cache
# lookup before falling back to the heuristic path. measure and append exercise
# TurboMind's in-process measurer and are blocked unless
# DS4_V100_TURBOMIND_ALLOW_UNSAFE_MEASURE=1 because the Sprint 129 full
# appliance smoke hit a TurboMind measurer invalid-argument fatal.
# Small-route build fuses count/prefix/scatter for the production decode route
# shape. Sprint 108 validated correctness but did not improve the 8-slot target,
# so keep it opt-in for focused long-context diagnostics.
# DS4_V100_TURBOMIND_ROUTE_ROW_REDUCE=1 keeps a pair-to-row route map and
# replaces the packed TurboMind output clear plus atomic scatter-add with a
# deterministic per-token reduce. It is a Sprint 124 probe and remains off
# until same-binary V100 A/B accepts it.
# DS4_V100_TURBOMIND_ROUTE_ROW_REDUCE_H2=1 uses the Sprint 141 half2-vectorized
# by-pair reduce kernel when route-row reduce is enabled. It remains off
# because 128-slot served A/B was neutral.
# DS4_V100_TURBOMIND_INDEXED_A=1 passes compact token indices into TurboMind
# gate/up GEMMs and stores one FP16 activation row per active token instead of
# route-expanding activations. It is a Sprint 131 probe and remains off until
# V100 correctness and throughput A/B accepts it.
# DS4_V100_SINGLE_SLOT_ATTN_SCRATCH=1 reuses the existing stage scratch arena
# for single-slot attention temporaries only. It is default-on after Sprint 190
# filled-context replay validation; set to 0 as the rollback.
# DS4_V100_TURBOMIND_GRAPH=1 enables CUDA Graph replay around the routed
# TurboMind FFN core. It requires warmed scratch, route validation/profile/
# group-pipeline off, and falls back if capture fails or the temp scratch
# pointer moves. Sprint 199 promoted it for the production fused6_reduce path
# after the 16-slot/256K served gate improved continuation tok/s by about 19.7%
# versus the routed-executor-off production control.
# DS4_V100_TURBOMIND_PROFILE=1 adds CUDA-event timing around route build,
# activation gather, fused gate/up GEMM, SwiGLU, down GEMM, and scatter/reduce.
# It synchronizes between stages, so use it for diagnosis, not production tok/s.
# Set DS4_V100_MTP_SERVING=verify to expose the conservative MTP draft/verify
# diagnostics path. Verify mode can run with same-length active microbatches.
# Set commit only for the exact-verified one-slot MTP commit path.
# base uses the frozen PP/layer-scheduled replay server. tp-ep uses the
# TP8/EP8 resident HTTP harness and is the forward implementation path.
DS4_V100_TP_EP_BIN=./tools/ds4-v100-tp-ep-full-layer-smoke
DS4_V100_TP_EP_CONTRACT=/workspace/logs/sprint245-tp-ep-dense-f16-cache-contract/contract/tp-ep-pack-contract.tsv
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_DIRECT_INPUT_FILL=0
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_DENSE_EVENT_WAIT=1
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_SKIP_DENSE_STATS=0
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_FUSED_ATTN_INPUT_FILL=0
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_FUSED_INPUT_FILL=0
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_FUSED_ROPE_ROUND=0
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_FUSED_POOL_NORM=1
DS4_V100_TP_EP_TRUE_DS4_COMPRESSED_KV_FUSED_POOL_NORM_ROPE_ROUND=0
# Empty resolves to $DS4_V100_APPLIANCE_DIR/turbomind-pack-index.tsv.
DS4_V100_TP_EP_TM_INDEX=
DS4_V100_TP_EP_TOP_K=6
DS4_V100_TP_EP_KV_SLOT=7
DS4_V100_TP_EP_POSITION=100000
DS4_V100_MTP_SERVING=off
DS4_V100_MTP_TOP_K=5
DS4_V100_MTP_GPU=7
